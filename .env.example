# ─── Supabase (app mobile/web Expo) ───────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_PUBLIQUE

# ─── Base de données MongoDB ──────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=hodix

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=REMPLACER_PAR_CLE_ALEATOIRE_LONGUE
JWT_REFRESH_SECRET_KEY=REMPLACER_PAR_CLE_REFRESH_ALEATOIRE

# ─── Twilio OTP (Verify) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=VOTRE_ACCOUNT_SID
TWILIO_AUTH_TOKEN=VOTRE_AUTH_TOKEN
TWILIO_VERIFY_SERVICE_SID=VOTRE_VERIFY_SERVICE_SID

# ─── Twilio SMS (notifications) ───────────────────────────────────────────────
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Admins ───────────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAILS=admin@hodix.app,votre@email.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://hodix.app,https://www.hodix.app

# ─── Limites financières ──────────────────────────────────────────────────────
DAILY_WITHDRAWAL_LIMIT_XAF=500000

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
ENVIRONMENT=production
