# ─── Supabase (app mobile/web Expo) ───────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://lrbhojxlofweotajnrhh.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_PUBLIQUE

# ─── EAS Build (APK) — obligatoire pour que l'app mobile fonctionne ─────────
# L'URL est dans eas.json ; la clé anon doit être ajoutée sur expo.dev :
#   Project hodix → Environment variables → preview + apk + production
#   Name: EXPO_PUBLIC_SUPABASE_ANON_KEY
#   Value: clé « anon / publishable » depuis Supabase → Settings → API
# Puis relancer : eas build --platform android --profile preview

# ─── Site web (OAuth PKCE — doit correspondre à Supabase Site URL) ───────────
EXPO_PUBLIC_SITE_URL=https://www.hodix.app

# Vercel : définir aussi EXPO_PUBLIC_SUPABASE_URL et EXPO_PUBLIC_SUPABASE_ANON_KEY
# (build:web génère public/hodix-env.js en secours si absent)

# ─── Universal Links (iOS + Android App Links) ───────────────────────────────
# Apple Team ID : developer.apple.com → Membership → Team ID (10 caractères)
APPLE_TEAM_ID=
# Empreinte SHA-256 du certificat de signature Android (Play Console ou eas credentials)
ANDROID_SHA256_FINGERPRINT=

# ─── Base de données MongoDB ──────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=hodix

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=REMPLACER_PAR_CLE_ALEATOIRE_LONGUE
JWT_REFRESH_SECRET_KEY=REMPLACER_PAR_CLE_REFRESH_ALEATOIRE

# ─── Twilio OTP (Verify) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=VOTRE_ACCOUNT_SID
TWILIO_AUTH_TOKEN=VOTRE_AUTH_TOKEN
TWILIO_VERIFY_SERVICE_SID=VOTRE_VERIFY_SERVICE_SID

# ─── Twilio SMS (notifications) ───────────────────────────────────────────────
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── CinetPay (paiements électroniques — app Expo) ─────────────────────────────
EXPO_PUBLIC_CINETPAY_API_KEY=
EXPO_PUBLIC_CINETPAY_SITE_ID=
# Webhook auto-confirmation (défaut: {SUPABASE_URL}/functions/v1/cinetpay-webhook)
EXPO_PUBLIC_CINETPAY_NOTIFY_URL=https://lrbhojxlofweotajnrhh.supabase.co/functions/v1/cinetpay-webhook
EXPO_PUBLIC_CINETPAY_RETURN_URL=
# true = confirmer les paiements sans CinetPay (dev uniquement, ref. transaction ≥ 8 car.)
EXPO_PUBLIC_PAYMENT_SANDBOX=false

# ─── CinetPay Edge Functions (Supabase → Edge Functions → Secrets) ───────────
# Checkout verification (webhook cinetpay-webhook)
# CINETPAY_API_KEY=
# CINETPAY_SITE_ID=
# CINETPAY_WEBHOOK_SECRET=          # optionnel — header x-cinetpay-webhook-secret
# Transfer / disbursement (cinetpay-payout — Orange/MTN retrait wallet)
# CINETPAY_TRANSFER_APIKEY=
# CINETPAY_TRANSFER_PASSWORD=
# CINETPAY_PAYOUT_NOTIFY_URL=
# CINETPAY_PAYOUT_SANDBOX=true      # dev: marque le retrait completed sans virement réel

# ─── Paynote / Y-Note — MTN Mobile Money Cameroun ─────────────────────────────
# Active le routage MTN MoMo vers Paynote (au lieu de CinetPay) dans l'app.
EXPO_PUBLIC_PAYNOTE_MTN_ENABLED=false
# Secrets côté serveur uniquement (Supabase → Edge Functions → Secrets) :
#   PAYNOTE_CLIENT_ID         — OAuth client id (Basic Auth username)
#   PAYNOTE_CLIENT_SECRET     — OAuth client secret (Basic Auth password)
#   PAYNOTE_CUSTOMER_KEY      — customerkey (webpayment)
#   PAYNOTE_CUSTOMER_SECRET   — customersecret (webpayment)
#   PAYNOTE_WEBHOOK_URL       — optionnel ; défaut : <SUPABASE_URL>/functions/v1/paynote-webhook
# Déployer : supabase functions deploy paynote-mtn paynote-webhook

# ─── E-money licence (COBAC/CEMAC — Supabase emoney_license_config) ───────────
# Statut: sandbox | application | licensed | suspended
# EMONEY_LICENSE_NUMBER=   # renseigner après obtention COBAC

# ─── Fraude temps réel (Edge Function fraud-score) ───────────────────────────
# Déployée avec JWT — invoquée avant retraits/virements
# E2E_SUPABASE_URL=
# E2E_SUPABASE_ANON_KEY=
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=

# ─── Admins ───────────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAILS=admin@hodix.app,votre@email.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://hodix.app,https://www.hodix.app

# ─── Limites financières ──────────────────────────────────────────────────────
DAILY_WITHDRAWAL_LIMIT_XAF=500000

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
ENVIRONMENT=production

# ─── 2FA SMS (secrets à configurer dans Supabase → Edge Functions → Secrets) ──
# Si absents, l'OTP est livré par notification in-app (mode sandbox).
# TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN / TWILIO_FROM_NUMBER

# ─── Emails Resend (Edge Functions send-receipt + send-welcome) ──────────────
# 1. Créer une clé sur https://resend.com/api-keys (Sending access)
# 2. Vérifier votre domaine sur https://resend.com/domains
# 3. Configurer dans Supabase Dashboard → Edge Functions → Secrets :
#    RESEND_API_KEY=re_xxxxxxxx
#    RECEIPT_FROM_EMAIL=receipts@votredomaine.com
#    RECEIPT_FROM_NAME=HODIX
# Ou via CLI : supabase secrets set RESEND_API_KEY=re_xxx RECEIPT_FROM_EMAIL=...

# ─── KYC Smile Identity (Edge Functions verify-kyc + kyc-webhook) ─────────────
# SMILE_PARTNER_ID=your_partner_id
# SMILE_API_KEY=your_api_key
# SMILE_CALLBACK_URL=https://<project>.supabase.co/functions/v1/kyc-webhook
# KYC_WEBHOOK_SECRET=random_hex   # header Authorization ou x-webhook-secret

# ─── Observabilité Sentry (app mobile native) ────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENVIRONMENT=production

# ─── OTP SMS Twilio (send-otp + inscription) ────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxx   # recommandé (Verify API)
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx        # fallback Messages API

# ─── Push notifications (Edge Function send-push via Expo) ─────────────────
# Aucun secret requis — utilise push_tokens + Expo Push API.
# L'app enregistre le token via POST /notifications/push-token au login.

# ─── Tontines planifiées (Edge Function tontine-cron) ───────────────────────
# Migration 20260610210944_tontine_cron_schedule.sql : pg_cron horaire (0 * * * *).
# 1. supabase secrets set TONTINE_CRON_SECRET=<random_hex>
# 2. Vault (SQL Editor, une fois) :
# Vault secrets (Supabase SQL Editor) — requis pour push en arrière-plan + cron tontines :
#    select vault.create_secret('https://<ref>.supabase.co', 'project_url');
#    select vault.create_secret('<SUPABASE_SERVICE_ROLE_KEY>', 'service_role_key');
#    select vault.create_secret('<TONTINE_CRON_SECRET>', 'tontine_cron_secret');
# Rappels SMS, avancement auto des cycles, release escrow.
