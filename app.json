{
  "expo": {
    "name": "HODIX",
    "slug": "hodix",
    "owner": "hodixs-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hodix",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2847"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.hodix.mobile",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:www.hodix.app",
        "applinks:hodix.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F2847"
      },
      "package": "app.hodix.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.hodix.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "hodix.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "HODIX – Épargne & Tontines",
      "shortName": "HODIX",
      "description": "Plateforme africaine de finance participative. Gérez vos tontines, épargnez en groupe et payez en toute sécurité.",
      "themeColor": "#0F2847",
      "backgroundColor": "#F8FAFC",
      "lang": "fr",
      "scope": "/",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "HODIX utilise Face ID pour sécuriser l'accès à votre compte et confirmer vos transactions."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "HODIX a besoin d'accéder à vos photos pour le KYC.",
          "cameraPermission": "HODIX a besoin d'accéder à votre caméra pour le selfie KYC."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0F2847",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0",
            "minSdkVersion": 23,
            "buildArchs": ["armeabi-v7a", "arm64-v8a"],
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "13.4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "452e134d-362a-4310-8e56-7c2087298d2b"
      },
      "router": {
        "origin": false
      }
    }
  }
}
